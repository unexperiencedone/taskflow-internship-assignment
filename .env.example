# Database: Use SQLite local file for easy testing, or PostgreSQL connection string
DATABASE_URL="file:./dev.db"
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/intern_project?schema=public"

# JWT Auth Secret
JWT_SECRET="your-jwt-secret-key-here"

# Redis Cache URL (optional, fallback is in-memory mock if Redis is unavailable)
REDIS_URL="redis://localhost:6379"

# Port (optional)
PORT=3000
